{
  "name": "aria-ui-monorepo",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "Monorepo for aria-ui",
  "scripts": {
    "build": "turbo run build && pnpm run build:tsc",
    "build:packages": "turbo run build --filter './packages/*'",
    "build:tsc": "tsc -b .",
    "watch": "turbo watch build --filter './packages/*'",
    "change": "changeset",
    "dev": "pnpm --filter aria-ui-website dev",
    "ci:publish": "pnpm run build && changeset publish",
    "ci:publish:pr": "pnpm run build && pnpx pkg-pr-new publish --pnpm ./packages/*",
    "ci:version": "changeset version && pnpm install --no-frozen-lockfile && pnpm run fix",
    "fix": "pnpm run fix:oxfmt && pnpm run fix:eslint && pnpm run fix:tsconfig",
    "fix:eslint": "eslint --fix .",
    "fix:oxfmt": "oxfmt .",
    "fix:tsconfig": "monorepo-typescript-references fix",
    "lint": "pnpm run lint:ts && pnpm run lint:eslint && pnpm run lint:knip && pnpm run lint:oxfmt",
    "lint:eslint": "eslint .",
    "lint:oxfmt": "oxfmt --check .",
    "lint:ts": "tsc -b .",
    "lint:knip": "knip",
    "typecheck": "tsc -b",
    "test": "vitest",
    "pretest": "playwright install chromium",
    "website": "pnpm run --filter aria-ui-website dev"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@ocavue/eslint-config": "^4.5.3",
    "@ocavue/tsconfig": "^0.7.1",
    "@types/node": "^24.12.0",
    "eslint": "^10.2.0",
    "knip": "^6.4.1",
    "monorepo-typescript-references": "^1.1.1",
    "oxfmt": "^0.44.0",
    "playwright": "^1.59.1",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
